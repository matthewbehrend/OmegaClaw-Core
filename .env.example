# Copy to .env and fill in values:  cp .env.example .env

# ---- LLM API Keys (held by proxy, never enter agent container) ----
# Set the key for your chosen provider. Leave others blank.
ANTHROPIC_API_KEY=
ASIONE_API_KEY=
ASI_API_KEY=
OPENAI_API_KEY=

# ---- Agent Configuration ----
# Provider options: Anthropic or OpenAI or ASICloud or ASIOne
PROVIDER=Anthropic
EMBEDDING_PROVIDER=Local
# Owner auth secret. If set, the first user to send "auth <secret>" becomes
# the sole accepted sender. If empty, any user on the channel can interact.
# To allow any user on the chat to interact, leave OMEGACLAW_AUTH_SECRET empty.
# Generate one with:  openssl rand -base64 24
OMEGACLAW_AUTH_SECRET=

# ---- Communication Channel ----
# Set COMM_CHANNEL to the channel you want: irc, telegram, or mattermost.
COMM_CHANNEL=irc

# IRC
IRC_CHANNEL=##omegaclaw
IRC_SERVER=irc.quakenet.org
IRC_PORT=6667
# For restricted mode: set IRC_SERVER=irc-proxy above and uncomment:
# IRC_UPSTREAM_HOST=irc.quakenet.org

# Telegram
TG_BOT_TOKEN=
TG_POLL_TIMEOUT=20

# Mattermost
MM_URL=
MM_CHANNEL_ID=
MM_BOT_TOKEN=

# ---- Image (optional, to use a pre-built image instead of building) ----
# OMEGACLAW_IMAGE=singularitynet/omegaclaw:latest
